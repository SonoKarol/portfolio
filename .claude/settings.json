{
  "$comment": "Permessi per Claude Code e i subagent su questo progetto. allow = consentito senza chiedere; ask = chiede conferma; deny = vietato.",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx create-next-app *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git pull *)",
      "Bash(git remote *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh repo create *)",
      "Bash(gh *)",
      "Bash(vercel *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git reset --hard *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/secrets/**)",
      "Bash(git push --force *)",
      "Bash(rm -rf /*)"
    ]
  }
}
